{
  "name": "backend",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\" && tsc",
    "lint": "eslint . --max-warnings=0",
    "format": "prettier --write \"{src,scripts}/**/*.ts\" \"*.{json,mjs}\"",
    "format:check": "prettier --check \"{src,scripts}/**/*.ts\" \"*.{json,mjs}\"",
    "test": "jest --runInBand",
    "typecheck": "tsc --noEmit",
    "start": "node dist/src/server.js",
    "seed:meals": "ts-node scripts/seedMeals.ts",
    "seed:demo-users": "ts-node scripts/seedDemoUsers.ts",
    "migrate:money-cents": "ts-node scripts/migrateMoneyToCents.ts",
    "localize:meals": "ts-node scripts/localizeMeals.ts",
    "make:admin": "ts-node scripts/makeAdmin.ts"
  },
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^4.22.1",
    "mongodb": "^7.0.0",
    "mongoose": "^9.0.2",
    "stripe": "^22.2.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.0.3",
    "eslint": "^9.39.4",
    "globals": "^17.6.0",
    "jest": "^30.4.2",
    "prettier": "^3.8.3",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.60.1"
  }
}
